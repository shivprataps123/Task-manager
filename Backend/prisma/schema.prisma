datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String?

  teams         TeamMember[]
  createdTeams  Team[]       @relation("TeamOwner")
  assignedTasks Task[]       @relation("AssignedTasks")
  comments      Comment[]
  activities    Activity[] 

  createdAt     DateTime     @default(now())
}

model Team {
  id   String @id @default(uuid())
  name String

  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])

  members  TeamMember[]
  projects Project[]
  invites     TeamInvite[]  

  createdAt DateTime @default(now())
}

model TeamMember {
  id String @id @default(uuid())

  userId String
  teamId String
  role   String // owner, admin, member

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model TeamInvite {
  id        String   @id @default(uuid())
  teamId    String
  token     String   @unique
  expiresAt DateTime

  team      Team @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
}

model Project {
  id   String @id @default(uuid())
  name String

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  tasks Task[]
  activities Activity[] 
  labels Label[]
  
  createdAt DateTime @default(now())
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?
  status      String // todo, in-progress, done

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  assignedToId String?
  assignedTo   User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  comments     Comment[]
  labels       TaskLabel[]

  createdAt DateTime @default(now())
}

model Comment {
  id   String @id @default(uuid())
  text String

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id])
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(uuid())

  action    String   // "task_created", "task_updated", etc.
  entity    String   // "task", "comment"

  entityId  String   // taskId or commentId

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

model Label {
  id    String @id @default(uuid())
  name  String
  color String // hex color code

  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  tasks     TaskLabel[]

  createdAt DateTime @default(now())

  @@unique([name, projectId])
}

model TaskLabel {
  id String @id @default(uuid())

  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id])
  label Label @relation(fields: [labelId], references: [id])

  @@unique([taskId, labelId])
}